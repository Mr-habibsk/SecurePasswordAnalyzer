<Window x:Class="SecurePasswordAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="450"
        Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="20"
            Background="#2B2B2B"
            Padding="20">

        <Border.Effect>
            <DropShadowEffect BlurRadius="35" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>

            <!-- TOP BAR -->
            <Grid Height="40" VerticalAlignment="Top" MouseDown="Window_MouseDown">

                <TextBlock Text="🔐 Secure Password Analyzer"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="—"
                            Width="35"
                            Height="35"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Minimize_Click"/>

                    <Button Content="✕"
                            Width="35"
                            Height="35"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Close_Click"/>

                </StackPanel>

            </Grid>

            <!-- MAIN CONTENT -->
            <StackPanel Margin="0,60,0,0">

                <!-- PASSWORD BOX -->
                <Border CornerRadius="8" Background="#3A3A3A" Padding="6">

                    <Grid>

                        <PasswordBox x:Name="txtPassword"
                                     Height="30"
                                     FontSize="15"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     PasswordChanged="PasswordChanged"/>

                        <TextBox x:Name="txtVisiblePassword"
                                 Visibility="Collapsed"
                                 Height="30"
                                 FontSize="15"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 TextChanged="PasswordChanged"/>

                    </Grid>

                </Border>

                <!-- SHOW PASSWORD -->
                <CheckBox Content="Show Password"
                          Margin="0,8,0,10"
                          Foreground="White"
                          Checked="ShowPassword_Checked"
                          Unchecked="ShowPassword_Unchecked"/>

                <!-- ANALYZE BUTTON -->
                <Button Height="35"
                        FontWeight="Bold"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Analyze_Click">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4CAF50"/>
                            <GradientStop Color="#2E7D32" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                    Analyze Password

                </Button>

                <!-- GENERATE PASSWORD -->
                <Button Content="Generate Secure Password"
                        Height="35"
                        Margin="0,10,0,0"
                        Click="GeneratePassword_Click"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"/>

                <!-- STRENGTH BAR -->
                <ProgressBar x:Name="strengthBar"
                             Height="18"
                             Maximum="5"
                             Margin="0,20,0,0"/>

                <TextBlock x:Name="txtStrength"
                           Foreground="White"
                           FontSize="15"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="txtCrackTime"
                           Foreground="#6EC6FF"
                           Margin="0,5,0,0"/>

                <TextBlock x:Name="txtAdvice"
                           Foreground="#9CCC65"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>

            </StackPanel>

        </Grid>

    </Border>

</Window>